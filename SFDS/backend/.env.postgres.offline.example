# SFDS offline PostgreSQL profile for the factory server.
# Copy these values into your Windows environment or a local .env loader.
# The database server is expected to run locally, preferably by Docker:
#   docker compose --env-file docker/postgres.env.example -f docker-compose.postgres.yml up -d
# Normal server startup should use:
#   sfds.bat

SFDS_DB_BACKEND=postgresql
SFDS_POSTGRES_HOST=127.0.0.1
SFDS_POSTGRES_PORT=5432
SFDS_POSTGRES_DB=sfds_offline
SFDS_POSTGRES_USER=sfds_app
SFDS_POSTGRES_PASSWORD=change_this_password

# Equivalent single URL form. If set, it overrides the variables above.
# SFDS_DATABASE_URL=postgresql+psycopg://sfds_app:change_this_password@127.0.0.1:5432/sfds_offline

# Small pool is enough for one factory edge machine.
SFDS_DB_POOL_SIZE=5
SFDS_DB_MAX_OVERFLOW=10
SFDS_DB_POOL_RECYCLE_SECONDS=1800
