# Offline Docker PostgreSQL profile for an SFDS factory server.
# Use this file with:
#   docker compose --env-file docker/postgres.env.example -f docker-compose.postgres.yml up -d
#
# For production, copy the values into your own env file and change the password.

SFDS_POSTGRES_IMAGE=postgres:16-alpine
SFDS_POSTGRES_CONTAINER=sfds_postgres
SFDS_POSTGRES_VOLUME=sfds_postgres_data

# Keep this at 127.0.0.1 for the factory server. Client/operator PCs should
# connect to the SFDS frontend/backend, not directly to PostgreSQL.
# Use 0.0.0.0 only when another trusted LAN server must connect directly.
SFDS_POSTGRES_BIND=127.0.0.1
SFDS_POSTGRES_PORT=5432

SFDS_POSTGRES_DB=sfds_offline
SFDS_POSTGRES_USER=sfds_app
SFDS_POSTGRES_PASSWORD=change_this_password
SFDS_TIMEZONE=Asia/Bangkok

# Conservative defaults for a small factory edge PC.
SFDS_POSTGRES_MAX_CONNECTIONS=100
SFDS_POSTGRES_SHARED_BUFFERS=256MB
SFDS_POSTGRES_WORK_MEM=8MB
SFDS_POSTGRES_MAINTENANCE_WORK_MEM=128MB
SFDS_POSTGRES_EFFECTIVE_CACHE_SIZE=1GB

# Backend variables. sfds.bat builds SFDS_DATABASE_URL automatically from these.
SFDS_DB_BACKEND=postgresql
